@page "/outbounds/create"
@using Microsoft.AspNetCore.Components.Authorization
@using PanelUserInventoryManagement.Auth
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager Nav
@inject NotificationService NotificationService
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider

@if (!isAuthorized)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="height: 60vh;">
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Filled" Style="max-width:500px;">
            <strong>Acceso denegado.</strong> Solo los usuarios con perfil <strong>Jefe de Bodega</strong> pueden registrar salidas de inventario.
        </RadzenAlert>
        <RadzenButton Text="Volver al inicio" Icon="home" ButtonStyle="ButtonStyle.Base" Click='() => Nav.NavigateTo("/")' />
    </RadzenStack>
}
else
{
    <RadzenStack Gap="1.5rem" class="rz-p-4">

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
            <RadzenIcon Icon="output" Style="font-size:2rem; color: var(--rz-primary);" />
            <RadzenText TextStyle="TextStyle.H5" Style="margin:0; font-weight:700;">
                Registrar Salida de Inventario
            </RadzenText>
        </RadzenStack>

        <RadzenCard>
            <RadzenStack Gap="1.25rem">
                <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:600;">
                    Configuración de la Salida
                </RadzenText>

                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenFormField Text="Sucursal Destino" Variant="Variant.Outlined" Style="width:100%;">
                            <RadzenDropDown @bind-Value="selectedBranchId"
                                            Data="branches"
                                            TextProperty="Name"
                                            ValueProperty="Id"
                                            Placeholder="Selecciona una sucursal"
                                            Style="width:100%;" />
                        </RadzenFormField>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenFormField Text="Producto" Variant="Variant.Outlined" Style="width:100%;">
                            <RadzenDropDown @bind-Value="selectedProductId"
                                            Data="products"
                                            TextProperty="Name"
                                            ValueProperty="Id"
                                            Placeholder="Selecciona un producto"
                                            AllowFiltering="true"
                                            Style="width:100%;" />
                        </RadzenFormField>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="2">
                        <RadzenFormField Text="Cantidad" Variant="Variant.Outlined" Style="width:100%;">
                            <RadzenNumeric @bind-Value="quantity" Min="1" Style="width:100%;" />
                        </RadzenFormField>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="2" Style="display:flex; align-items:flex-end;">
                        <RadzenButton Text="Agregar"
                                      Icon="add_circle"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Style="width:100%; height:48px;"
                                      Click="AddItem"
                                      Disabled="@(selectedBranchId == Guid.Empty || selectedProductId == Guid.Empty || quantity <= 0)" />
                    </RadzenColumn>
                </RadzenRow>

                @if (addError != null)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat"
                                 Size="AlertSize.Small" AllowClose="false">
                        @addError
                    </RadzenAlert>
                }
            </RadzenStack>
        </RadzenCard>

        @if (outboundItems.Count > 0)
        {
            <RadzenCard>
                <RadzenStack Gap="1rem">
                    <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:600;">
                        Productos a Enviar
                    </RadzenText>

                    <RadzenDataGrid Data="outboundItems" TItem="OutboundItem"
                                    AllowSorting="true"
                                    Style="width:100%;">
                        <Columns>
                            <RadzenDataGridColumn TItem="OutboundItem" Property="ProductId" Title="ID Producto" Width="220px">
                                <Template Context="item">
                                    <RadzenText TextStyle="TextStyle.Caption" Style="font-family:monospace;">
                                        @item.ProductId.ToString().ToUpper()
                                    </RadzenText>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="OutboundItem" Property="ProductName" Title="Nombre" />

                            <RadzenDataGridColumn TItem="OutboundItem" Property="Sku" Title="SKU" Width="140px" />

                            <RadzenDataGridColumn TItem="OutboundItem" Property="Quantity" Title="Cantidad" Width="100px" />

                            <RadzenDataGridColumn TItem="OutboundItem" Title="Costo Unit. Est." Width="150px">
                                <Template Context="item">
                                    L @item.UnitCost.ToString("N2")
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="OutboundItem" Title="Subtotal Est." Width="150px">
                                <Template Context="item">
                                    L @((item.UnitCost * item.Quantity).ToString("N2"))
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="OutboundItem" Title="Acciones" Width="80px" Sortable="false">
                                <Template Context="item">
                                    <RadzenButton Icon="delete"
                                                  ButtonStyle="ButtonStyle.Danger"
                                                  Variant="Variant.Text"
                                                  Size="ButtonSize.Small"
                                                  Click="() => RemoveItem(item)" />
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>

                    <RadzenStack Orientation="Orientation.Horizontal"
                                 JustifyContent="JustifyContent.End"
                                 AlignItems="AlignItems.Center"
                                 Gap="1.5rem">

                        <RadzenText TextStyle="TextStyle.Body1">
                            <strong>Items:</strong> @outboundItems.Count producto(s) —
                            <strong>Cant. total:</strong> @outboundItems.Sum(i => i.Quantity) unidades —
                            <strong>Total estimado:</strong> L @outboundItems.Sum(i => i.UnitCost * i.Quantity).ToString("N2")
                        </RadzenText>

                        <RadzenButton Text="Registrar Salida"
                                      Icon="send"
                                      ButtonStyle="ButtonStyle.Success"
                                      IsBusy="isSubmitting"
                                      BusyText="Registrando..."
                                      Click="SubmitOutbound" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenCard>
        }

        @if (outboundResult != null)
        {
            <RadzenCard Style="border: 2px solid var(--rz-success);">
                <RadzenStack Gap="0.75rem">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenIcon Icon="check_circle" Style="color: var(--rz-success); font-size:1.5rem;" />
                        <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:700; color: var(--rz-success);">
                            Salida Registrada Exitosamente
                        </RadzenText>
                    </RadzenStack>
                    <RadzenRow>
                        <RadzenColumn Size="6" SizeMD="3">
                            <RadzenText TextStyle="TextStyle.Caption">Número de Salida</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:600;">@outboundResult.OutboundNumber</RadzenText>
                        </RadzenColumn>
                        <RadzenColumn Size="6" SizeMD="3">
                            <RadzenText TextStyle="TextStyle.Caption">Estado</RadzenText>
                            <RadzenBadge Text="@outboundResult.Status" BadgeStyle="BadgeStyle.Info" />
                        </RadzenColumn>
                        <RadzenColumn Size="6" SizeMD="3">
                            <RadzenText TextStyle="TextStyle.Caption">Fecha</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:600;">
                                @outboundResult.OutboundDate.ToString("dd/MM/yyyy HH:mm")
                            </RadzenText>
                        </RadzenColumn>
                        <RadzenColumn Size="6" SizeMD="3">
                            <RadzenText TextStyle="TextStyle.Caption">Costo Total</RadzenText>
                            <RadzenText TextStyle="TextStyle.H6" Style="font-weight:700; color: var(--rz-success);">
                                L @outboundResult.TotalCost.ToString("N2")
                            </RadzenText>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenStack>
            </RadzenCard>
        }

    </RadzenStack>
}


@code {
    private List<BranchDto> branches = [];
    private List<ProductDto> products = [];

    private Guid selectedBranchId;
    private Guid selectedProductId;
    private decimal quantity = 1;

    private List<OutboundItem> outboundItems = [];
    private string? addError;

    private bool isSubmitting = false;
    private OutboundResponseDto? outboundResult;

    private bool isAuthorized = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        foreach (var claim in user.Claims)
            Console.WriteLine($"Claim: {claim.Type} = {claim.Value}");

        isAuthorized = user.IsInRole("Jefe de Bodega");

        if (isAuthorized)
        {
            try
            {
                branches = await Http.GetFromJsonAsync<List<BranchDto>>("api/Locations/GetBranches") ?? [];
                products = await Http.GetFromJsonAsync<List<ProductDto>>("api/Products/GetActiveProducts") ?? [];
            }
            catch
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", "No se pudieron cargar los datos.");
            }
        }
    }

    private void AddItem()
    {
        addError = null;

        var product = products.FirstOrDefault(p => p.Id == selectedProductId);
        if (product == null) return;

        if (outboundItems.Any(i => i.ProductId == selectedProductId))
        {
            addError = "Este producto ya fue agregado. Elimínalo si deseas cambiar la cantidad.";
            return;
        }

        outboundItems = new List<OutboundItem>(outboundItems)
        {
            new OutboundItem
            {
                ProductId = product.Id,
                ProductName = product.Name,
                Sku = product.Sku,
                Quantity = quantity,
                UnitCost = product.UnitCost
            }
        };

        selectedProductId = Guid.Empty;
        quantity = 1;
        StateHasChanged();
    }

    private void RemoveItem(OutboundItem item)
    {
        outboundItems = outboundItems.Where(i => i != item).ToList();
        outboundResult = null;
        StateHasChanged();
    }

    private async Task SubmitOutbound()
    {
        if (selectedBranchId == Guid.Empty || outboundItems.Count == 0) 
            return;

        isSubmitting = true;
        outboundResult = null;
        addError = null;

        try
        {
            var payload = new
            {
                DestinationId = selectedBranchId,
                Items = outboundItems.Select(i => new
                {
                    ProductId = i.ProductId,
                    Quantity = i.Quantity
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync("api/Outbounds/CreateOutbound", payload);
            var result = await response.Content.ReadFromJsonAsync<ApiResponse<OutboundResponseDto>>();

            if (!response.IsSuccessStatusCode || result == null || !result.Succeeded)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error",
                    result?.Message ?? "No se pudo registrar la salida.");
                return;
            }

            outboundResult = result.Data;
            outboundItems.Clear();
            selectedBranchId = Guid.Empty;

            NotificationService.Notify(NotificationSeverity.Success, "Éxito",
                $"Salida {result.Data?.OutboundNumber} registrada correctamente.");
        }
        catch
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "No se pudo conectar al servidor.");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class BranchDto
    {
        public Guid Id { get; set; }

        public string Name { get; set; } = "";
    }

    public class ProductDto
    {
        public Guid Id { get; set; }

        public string Sku { get; set; } = "";

        public string Name { get; set; } = "";

        public string Brand { get; set; } = "";

        public decimal UnitCost { get; set; }
    }

    public class OutboundItem
    {
        public Guid ProductId { get; set; }

        public string ProductName { get; set; } = "";

        public string Sku { get; set; } = "";

        public decimal Quantity { get; set; }

        public decimal UnitCost { get; set; }
    }

    public class OutboundResponseDto
    {
        public Guid Id { get; set; }

        public string? OutboundNumber { get; set; }

        public string? Status { get; set; }

        public DateTime OutboundDate { get; set; }

        public decimal TotalCost { get; set; }
    }

    public class ApiResponse<T>
    {
        public bool Succeeded { get; set; }

        public string? Message { get; set; }

        public T? Data { get; set; }
    }
}